rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // dishes — public read for available dishes, admin write
    match /dishes/{dishId} {
      allow read: if resource.data.isAvailable == true;
      allow read, write: if request.auth != null;
    }

    // categories — public read, admin write
    match /categories/{catId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // restaurants — public read, admin write own document
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == restaurantId;
    }
  }
}
